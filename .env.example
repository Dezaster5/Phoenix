DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex list for dynamic hosts (for example ngrok):
# DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=https://.*\\.ngrok-free\\.app
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=
DJANGO_CORS_ALLOW_CREDENTIALS=False
DJANGO_CORS_EXPOSE_HEADERS=content-disposition
DJANGO_CORS_ALLOW_HEADERS_EXTRA=ngrok-skip-browser-warning
DJANGO_SECRET_KEY=change-me

POSTGRES_DB=phoenix
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=phoenix
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
# For Neon set require. Leave empty for local Docker Postgres.
POSTGRES_SSLMODE=
# Optional alternative to POSTGRES_*:
# DATABASE_URL=postgres://user:password@host:5432/dbname

ALLOW_PASSWORDLESS_LOGIN=True
# Allowed role codes for passwordless login.
# Safer production default is `employee`.
PASSWORDLESS_ROLES=employee
LOGIN_CHALLENGE_ENABLED=False
LOGIN_CHALLENGE_TTL_MINUTES=10
FRONTEND_BASE_URL=http://localhost:5173
PUBLIC_SUPPORT_EMAIL=
PUBLIC_LOGIN_REQUEST_SUBJECT=Запрос логина Phoenix Vault
# Use literal new lines if you want a custom template.
PUBLIC_LOGIN_REQUEST_TEMPLATE=Здравствуйте!\n\nПрошу выдать логин для доступа в Phoenix Vault.\nФИО: ____\nОтдел: ____\nДолжность: ____\nКорпоративная почта: ____\nНужные сервисы: ____\n\nСпасибо!

EMAIL_NOTIFICATIONS_ENABLED=False
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=phoenix-vault@example.com

# Optional: set a 32-byte base64 Fernet key for encryption.
FERNET_KEY=

# Optional: asymmetric envelope encryption for Credential.password.
# If public key is set, new secrets are encrypted with RSA-OAEP + AES-GCM.
# Decryption requires private key.
ASYMMETRIC_PUBLIC_KEY=
ASYMMETRIC_PRIVATE_KEY=
ASYMMETRIC_PUBLIC_KEY_PATH=keys/public_key.pem
ASYMMETRIC_PRIVATE_KEY_PATH=keys/private_key.pem

THROTTLE_LOGIN_BURST=10/min
THROTTLE_LOGIN_SUSTAINED=50/hour
THROTTLE_ACCESS_REQUEST_CREATE=20/day
LOG_LEVEL=INFO

SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
X_FRAME_OPTIONS=DENY
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
# Optional strict CSP for reverse-proxied production setups.
CONTENT_SECURITY_POLICY=
PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

RUN_MIGRATIONS=1
COLLECT_STATIC=0
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60

# Optional for dockerized ngrok tunnel (`docker compose --profile tunnel up -d ngrok`)
NGROK_AUTHTOKEN=
